{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://auralithai.com/schemas/index_job.schema.json",
  "title": "IndexJob",
  "description": "Request to index or update a repository's code index",
  "type": "object",
  "required": ["repo_id", "job_type"],
  "properties": {
    "job_id": {
      "type": "string",
      "description": "Unique identifier for this job",
      "format": "uuid"
    },
    "repo_id": {
      "type": "string",
      "description": "Unique identifier for the repository"
    },
    "job_type": {
      "type": "string",
      "enum": ["full", "incremental", "refresh", "delete"],
      "description": "Type of indexing operation"
    },
    "repo_url": {
      "type": "string",
      "description": "Git clone URL for the repository",
      "format": "uri"
    },
    "branch": {
      "type": "string",
      "description": "Branch to index",
      "default": "main"
    },
    "commit_sha": {
      "type": "string",
      "description": "Specific commit to index",
      "pattern": "^[a-f0-9]{40}$"
    },
    "base_sha": {
      "type": "string",
      "description": "Base commit for incremental indexing",
      "pattern": "^[a-f0-9]{40}$"
    },
    "changed_files": {
      "type": "array",
      "description": "Files changed (for incremental indexing)",
      "items": {
        "type": "string"
      }
    },
    "config": {
      "$ref": "#/definitions/IndexConfig"
    },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "high", "urgent"],
      "default": "normal"
    },
    "callback_url": {
      "type": "string",
      "description": "Webhook URL for job completion notification",
      "format": "uri"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of the request",
      "format": "date-time"
    }
  },
  "definitions": {
    "IndexConfig": {
      "type": "object",
      "description": "Configuration for the indexing job",
      "properties": {
        "profile": {
          "type": "string",
          "enum": ["default", "large-repo", "strict-security", "perf-focused"],
          "description": "Indexing profile to use"
        },
        "include_patterns": {
          "type": "array",
          "description": "File patterns to include",
          "items": {
            "type": "string"
          }
        },
        "exclude_patterns": {
          "type": "array",
          "description": "File patterns to exclude",
          "items": {
            "type": "string"
          }
        },
        "max_file_size_kb": {
          "type": "integer",
          "description": "Maximum file size to index in KB",
          "default": 1024
        },
        "chunk_size": {
          "type": "integer",
          "description": "Target chunk size in tokens",
          "default": 512
        },
        "chunk_overlap": {
          "type": "integer",
          "description": "Overlap between chunks in tokens",
          "default": 64
        },
        "enable_ast_chunking": {
          "type": "boolean",
          "description": "Use AST-aware chunking when available",
          "default": true
        },
        "languages": {
          "type": "array",
          "description": "Languages to index (empty = all detected)",
          "items": {
            "type": "string"
          }
        },
        "tiers": {
          "$ref": "#/definitions/TierConfig"
        }
      }
    },
    "TierConfig": {
      "type": "object",
      "description": "Tiered indexing configuration for large repos",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable tiered indexing",
          "default": false
        },
        "hot_paths": {
          "type": "array",
          "description": "High-priority paths (indexed first, always kept warm)",
          "items": {
            "type": "string"
          }
        },
        "cold_paths": {
          "type": "array",
          "description": "Low-priority paths (lazy indexed, may be evicted)",
          "items": {
            "type": "string"
          }
        },
        "max_hot_size_mb": {
          "type": "integer",
          "description": "Maximum size for hot index in MB",
          "default": 500
        }
      }
    }
  }
}
