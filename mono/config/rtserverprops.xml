<?xml version="1.0" encoding="UTF-8"?>
<!--
  ==============================================================================================
  AI-PR-Reviewer Server Configuration
  ==============================================================================================

  This file contains the configuration parameters for the AI-PR-Reviewer server.
  Platform authentication settings are in vcsplatforms.xml.

  Variables of the form ${ENV_VAR:default} are resolved at load time:
    1. Environment variable ENV_VAR
    2. The default value after the colon
    3. Empty string if neither is available

  ${aipr.home} is replaced with the RT_HOME installation directory.
  ==============================================================================================
-->
<serverproperties>

    <!-- ===================================================================== -->
    <!-- REST API Server                                                       -->
    <!-- ===================================================================== -->
    <server port="${SERVER_PORT:8080}" shutdown="graceful" context-path="/"/>

    <!-- ===================================================================== -->
    <!-- Database (PostgreSQL)                                                 -->
    <!-- ===================================================================== -->
    <database url="${DATABASE_URL:jdbc:postgresql://localhost:5432/aipr}"
              username="${DATABASE_USER:aipr}"
              password="${DATABASE_PASSWORD:aipr_secret}"
              driver="org.postgresql.Driver">

        <pool name="aipr-pool"
              max-size="${DB_POOL_SIZE:20}"
              min-idle="5"
              connection-timeout-ms="30000"
              idle-timeout-ms="600000"
              max-lifetime-ms="1800000"
              leak-detection-threshold-ms="60000"/>

        <flyway enabled="true"
                locations="classpath:db/migration"
                baseline-on-migrate="true"/>
    </database>

    <!-- ===================================================================== -->
    <!-- Redis                                                                 -->
    <!-- ===================================================================== -->
    <redis host="${REDIS_HOST:localhost}"
           port="${REDIS_PORT:6379}"
           password="${REDIS_PASSWORD:}"
           database="${REDIS_DATABASE:0}"
           timeout-ms="5000">

        <pool max-active="16" max-idle="8" min-idle="2" max-wait-ms="5000"/>

        <cluster enabled="${REDIS_CLUSTER_ENABLED:false}"
                 nodes="${REDIS_CLUSTER_NODES:}"/>
    </redis>

    <!-- ===================================================================== -->
    <!-- gRPC Server (Java — SDK clients, CLI connect here)                    -->
    <!-- ===================================================================== -->
    <grpc-server port="${GRPC_SERVER_PORT:9090}">

        <security enabled="${GRPC_TLS_ENABLED:true}"
                  cert-chain="${GRPC_SERVER_CERT:config/certificates/server.crt}"
                  private-key="${GRPC_SERVER_KEY:config/certificates/server.key}"
                  trust-certs="${GRPC_TRUST_CERT:config/certificates/ca.crt}"
                  client-auth="${GRPC_CLIENT_AUTH:OPTIONAL}"/>
    </grpc-server>

    <!-- ===================================================================== -->
    <!-- gRPC Engine Client (C++ engine — internal communication)              -->
    <!-- ===================================================================== -->
    <engine host="${ENGINE_HOST:localhost}"
            port="${ENGINE_PORT:50051}"
            timeout-ms="${ENGINE_TIMEOUT_MS:30000}"
            negotiation-type="${ENGINE_NEGOTIATION:TLS}">

        <!--
            For TLS/mTLS to the C++ engine, provide client certificate paths.
            For development: use PLAINTEXT negotiation and skip these.
        -->
        <tls cert-chain="${ENGINE_TLS_CERT:config/certificates/client.crt}"
             private-key="${ENGINE_TLS_KEY:config/certificates/client.key}"
             trust-certs="${ENGINE_TLS_CA:config/certificates/ca.crt}"/>

        <retry max-attempts="3"
               initial-backoff-ms="100"
               max-backoff-ms="5000"/>

        <pool max-channels="${ENGINE_MAX_CHANNELS:10}"
              idle-timeout-seconds="300"/>
    </engine>

    <!-- ===================================================================== -->
    <!-- LLM Provider                                                          -->
    <!-- ===================================================================== -->
    <llm provider="${LLM_PROVIDER:openai-compatible}"
         base-url="${LLM_BASE_URL:https://api.openai.com/v1}"
         api-key="${LLM_API_KEY:}"
         model="${LLM_MODEL:gpt-4-turbo-preview}"
         max-tokens="${LLM_MAX_TOKENS:4096}"
         temperature="${LLM_TEMPERATURE:0.1}"
         timeout-ms="${LLM_TIMEOUT_MS:120000}"/>

    <!-- ===================================================================== -->
    <!-- Review Settings                                                       -->
    <!-- ===================================================================== -->
    <review max-diff-size="${MAX_DIFF_SIZE:500000}"
            max-files-per-pr="${MAX_FILES_PER_PR:100}"
            max-comments="${MAX_COMMENTS:50}"
            enable-heuristics="true"
            enable-context-retrieval="true"/>

    <!-- ===================================================================== -->
    <!-- Rate Limiting                                                         -->
    <!-- ===================================================================== -->
    <rate-limit enabled="${RATE_LIMIT_ENABLED:true}"
                reviews-per-hour="${RATE_LIMIT_REVIEWS:500}"
                index-requests-per-hour="${RATE_LIMIT_INDEX:50}"/>

    <!-- ===================================================================== -->
    <!-- Security                                                              -->
    <!-- ===================================================================== -->
    <security jwt-secret="${JWT_SECRET:}"
              jwt-expiration-ms="${JWT_EXPIRATION_MS:3600000}"
              allowed-origins="${ALLOWED_ORIGINS:http://localhost:3000}"
              encryption-key="${AIPR_ENCRYPTION_KEY:}"/>

    <!-- ===================================================================== -->
    <!-- Storage                                                               -->
    <!-- ===================================================================== -->
    <storage type="${STORAGE_TYPE:local}">
        <local base-path="${STORAGE_PATH:./data}"/>
        <s3 bucket="${S3_BUCKET:}" region="${S3_REGION:us-east-1}"/>
    </storage>

    <!-- ===================================================================== -->
    <!-- Repository Cloning                                                    -->
    <!-- ===================================================================== -->
    <repositories base-path="${REPOS_PATH:./repos}"/>

    <!-- ===================================================================== -->
    <!-- Logging                                                               -->
    <!-- ===================================================================== -->
    <logging root-level="${LOG_LEVEL_ROOT:INFO}" app-level="${LOG_LEVEL_APP:DEBUG}"/>

</serverproperties>

