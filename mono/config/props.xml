<?xml version="1.0" encoding="UTF-8"?>
<!--
    AI-PR-Reviewer Configuration Properties
    
    This file contains all configurable properties for the AI-PR-Reviewer system.
    Environment variables take precedence over values defined here.
    
    For production, use environment variables or secrets management.
-->
<configuration>
    
    <!-- ===================================================================== -->
    <!-- Database Configuration (PostgreSQL) -->
    <!-- ===================================================================== -->
    <database>
        <connection>
            <url>${DB_URL:jdbc:postgresql://localhost:5432/aipr}</url>
            <username>${DB_USERNAME:aipr}</username>
            <password>${DB_PASSWORD:aipr_secret}</password>
            <driver>org.postgresql.Driver</driver>
        </connection>
        <pool>
            <name>aipr-pool</name>
            <max-size>${DB_POOL_SIZE:20}</max-size>
            <min-idle>5</min-idle>
            <connection-timeout-ms>30000</connection-timeout-ms>
            <idle-timeout-ms>300000</idle-timeout-ms>
            <max-lifetime-ms>1800000</max-lifetime-ms>
        </pool>
        <flyway>
            <enabled>true</enabled>
            <locations>classpath:db/migration</locations>
            <baseline-on-migrate>true</baseline-on-migrate>
        </flyway>
    </database>
    
    <!-- ===================================================================== -->
    <!-- Redis Configuration -->
    <!-- ===================================================================== -->
    <redis>
        <connection>
            <host>${REDIS_HOST:localhost}</host>
            <port>${REDIS_PORT:6379}</port>
            <password>${REDIS_PASSWORD:}</password>
            <database>${REDIS_DATABASE:0}</database>
            <timeout-ms>5000</timeout-ms>
        </connection>
        <pool>
            <max-active>16</max-active>
            <max-idle>8</max-idle>
            <min-idle>2</min-idle>
            <max-wait-ms>5000</max-wait-ms>
        </pool>
        <!-- Optional: Redis Cluster for production -->
        <cluster>
            <enabled>${REDIS_CLUSTER_ENABLED:false}</enabled>
            <nodes>${REDIS_CLUSTER_NODES:}</nodes>
        </cluster>
    </redis>
    
    <!-- ===================================================================== -->
    <!-- gRPC Server Configuration (Java Server - External API) -->
    <!-- ===================================================================== -->
    <grpc-server>
        <port>${GRPC_SERVER_PORT:9090}</port>
        <max-inbound-message-size>16MB</max-inbound-message-size>
        <max-inbound-metadata-size>8KB</max-inbound-metadata-size>
        <enable-reflection>true</enable-reflection>
        <keep-alive>
            <time-seconds>60</time-seconds>
            <timeout-seconds>20</timeout-seconds>
            <permit-without-calls>true</permit-without-calls>
        </keep-alive>
        <security>
            <enabled>${GRPC_TLS_ENABLED:false}</enabled>
            <cert-chain>${GRPC_TLS_CERT:}</cert-chain>
            <private-key>${GRPC_TLS_KEY:}</private-key>
        </security>
        <!-- Number of gRPC server instances (for scaling documentation) -->
        <instances>
            <count>${GRPC_INSTANCE_COUNT:1}</count>
            <description>
                Single instance for dev/small deployments.
                For production, deploy multiple instances behind a load balancer.
                Each instance handles both REST (via grpc-gateway) and gRPC traffic.
            </description>
        </instances>
    </grpc-server>
    
    <!-- ===================================================================== -->
    <!-- gRPC Engine Configuration (C++ Engine - Internal Communication) -->
    <!-- ===================================================================== -->
    <grpc-engine>
        <!-- Primary engine instance -->
        <primary>
            <host>${ENGINE_HOST:localhost}</host>
            <port>${ENGINE_PORT:50051}</port>
        </primary>
        
        <!-- Additional engine instances for load balancing (production) -->
        <instances>
            <instance>
                <host>${ENGINE_HOST_1:localhost}</host>
                <port>${ENGINE_PORT_1:50051}</port>
                <weight>1</weight>
            </instance>
            <instance>
                <host>${ENGINE_HOST_2:}</host>
                <port>${ENGINE_PORT_2:50052}</port>
                <weight>1</weight>
            </instance>
            <instance>
                <host>${ENGINE_HOST_3:}</host>
                <port>${ENGINE_PORT_3:50053}</port>
                <weight>1</weight>
            </instance>
        </instances>
        
        <connection>
            <negotiation-type>${ENGINE_NEGOTIATION:PLAINTEXT}</negotiation-type>
            <deadline-ms>30000</deadline-ms>
        </connection>
        <retry>
            <max-attempts>3</max-attempts>
            <initial-backoff-ms>100</initial-backoff-ms>
            <max-backoff-ms>5000</max-backoff-ms>
            <backoff-multiplier>2.0</backoff-multiplier>
        </retry>
        <pool>
            <max-channels>10</max-channels>
            <idle-timeout-seconds>300</idle-timeout-seconds>
        </pool>
    </grpc-engine>
    
    <!-- ===================================================================== -->
    <!-- REST API Server Configuration -->
    <!-- ===================================================================== -->
    <rest-server>
        <port>${SERVER_PORT:8080}</port>
        <context-path>/</context-path>
        <compression>
            <enabled>true</enabled>
            <mime-types>application/json,application/xml,text/plain</mime-types>
            <min-response-size>1024</min-response-size>
        </compression>
    </rest-server>
    
    <!-- ===================================================================== -->
    <!-- LLM Configuration -->
    <!-- ===================================================================== -->
    <llm>
        <provider>${LLM_PROVIDER:openai}</provider>
        
        <openai>
            <api-key>${OPENAI_API_KEY:}</api-key>
            <model>${OPENAI_MODEL:gpt-4-turbo}</model>
            <base-url>${OPENAI_BASE_URL:https://api.openai.com/v1}</base-url>
            <temperature>0.1</temperature>
            <max-tokens>4096</max-tokens>
            <timeout-ms>60000</timeout-ms>
        </openai>
        
        <anthropic>
            <api-key>${ANTHROPIC_API_KEY:}</api-key>
            <model>${ANTHROPIC_MODEL:claude-3-opus-20240229}</model>
            <max-tokens>4096</max-tokens>
            <timeout-ms>60000</timeout-ms>
        </anthropic>
        
        <azure-openai>
            <api-key>${AZURE_OPENAI_API_KEY:}</api-key>
            <endpoint>${AZURE_OPENAI_ENDPOINT:}</endpoint>
            <deployment-name>${AZURE_OPENAI_DEPLOYMENT:}</deployment-name>
            <api-version>2024-02-15-preview</api-version>
        </azure-openai>
        
        <ollama>
            <base-url>${OLLAMA_BASE_URL:http://localhost:11434}</base-url>
            <model>${OLLAMA_MODEL:codellama:34b}</model>
        </ollama>
        
        <rate-limit>
            <requests-per-minute>${LLM_RATE_LIMIT:60}</requests-per-minute>
            <tokens-per-minute>${LLM_TOKEN_LIMIT:100000}</tokens-per-minute>
        </rate-limit>
    </llm>
    
    <!-- ===================================================================== -->
    <!-- Platform Integrations -->
    <!-- ===================================================================== -->
    <integrations>
        <github>
            <app-id>${GITHUB_APP_ID:}</app-id>
            <private-key-path>${GITHUB_PRIVATE_KEY_PATH:}</private-key-path>
            <private-key>${GITHUB_PRIVATE_KEY:}</private-key>
            <webhook-secret>${GITHUB_WEBHOOK_SECRET:}</webhook-secret>
            <api-url>${GITHUB_API_URL:https://api.github.com}</api-url>
        </github>
        
        <gitlab>
            <token>${GITLAB_TOKEN:}</token>
            <webhook-secret>${GITLAB_WEBHOOK_SECRET:}</webhook-secret>
            <api-url>${GITLAB_API_URL:https://gitlab.com/api/v4}</api-url>
        </gitlab>
        
        <bitbucket>
            <client-id>${BITBUCKET_CLIENT_ID:}</client-id>
            <client-secret>${BITBUCKET_CLIENT_SECRET:}</client-secret>
            <api-url>${BITBUCKET_API_URL:https://api.bitbucket.org/2.0}</api-url>
        </bitbucket>
    </integrations>
    
    <!-- ===================================================================== -->
    <!-- Security Configuration -->
    <!-- ===================================================================== -->
    <security>
        <jwt>
            <secret>${JWT_SECRET:change-me-in-production}</secret>
            <expiration-ms>86400000</expiration-ms>
        </jwt>
        <cors>
            <allowed-origins>${CORS_ORIGINS:http://localhost:3000}</allowed-origins>
            <allowed-methods>GET,POST,PUT,DELETE,OPTIONS</allowed-methods>
            <allow-credentials>true</allow-credentials>
        </cors>
    </security>
    
    <!-- ===================================================================== -->
    <!-- Rate Limiting -->
    <!-- ===================================================================== -->
    <rate-limit>
        <enabled>true</enabled>
        <reviews-per-hour>${RATE_LIMIT_REVIEWS:500}</reviews-per-hour>
        <index-requests-per-hour>${RATE_LIMIT_INDEX:50}</index-requests-per-hour>
        <api-requests-per-minute>${RATE_LIMIT_API:100}</api-requests-per-minute>
    </rate-limit>
    
    <!-- ===================================================================== -->
    <!-- Storage Configuration -->
    <!-- ===================================================================== -->
    <storage>
        <type>${STORAGE_TYPE:local}</type>
        <local>
            <base-path>${STORAGE_PATH:./data}</base-path>
        </local>
        <s3>
            <bucket>${S3_BUCKET:}</bucket>
            <region>${S3_REGION:us-east-1}</region>
            <access-key>${AWS_ACCESS_KEY_ID:}</access-key>
            <secret-key>${AWS_SECRET_ACCESS_KEY:}</secret-key>
        </s3>
    </storage>
    
</configuration>
