<?xml version="1.0" encoding="UTF-8"?>
<!--
  ==============================================================================================
  RTVortex : Version Control Platform Configuration
  ==============================================================================================

  Configure which platforms to enable and their authentication settings.
  Enable at least one platform for the server to accept webhooks and post reviews.

  For self-hosted instances (GitHub Enterprise, self-hosted GitLab, Bitbucket Server),
  override the base-url and api-url attributes accordingly.
  ==============================================================================================
-->
<platforms>

    <!-- ===================================================================== -->
    <!-- GitHub                                                                -->
    <!-- ===================================================================== -->
    <github enabled="${GITHUB_ENABLED:true}"
            base-url="${GITHUB_BASE_URL:https://github.com}"
            api-url="${GITHUB_API_URL:https://api.github.com}">

        <!-- OAuth App — create at: GitHub Settings > Developer settings > OAuth Apps -->
        <oauth client-id="${GITHUB_CLIENT_ID:}"
               client-secret="${GITHUB_CLIENT_SECRET:}"
               callback-path="/api/v1/auth/github/callback"
               scopes="repo,read:org,user:email"/>

        <!-- GitHub App (optional, for org-level access) -->
        <app enabled="false"
             app-id="${GITHUB_APP_ID:}"
             private-key-path="${GITHUB_PRIVATE_KEY_PATH:}"/>

        <!-- Webhook — GitHub sends X-Hub-Signature-256 signed with this secret -->
        <webhook enabled="true"
                 secret="${GITHUB_WEBHOOK_SECRET:}"
                 path="/api/v1/webhooks/github"/>

        <!-- PAT fallback (used when GitHub App is not configured) -->
        <token value="${GITHUB_TOKEN:}"/>
    </github>

    <!-- ===================================================================== -->
    <!-- GitLab                                                                -->
    <!-- ===================================================================== -->
    <gitlab enabled="${GITLAB_ENABLED:false}"
            base-url="${GITLAB_BASE_URL:https://gitlab.com}">

        <!-- OAuth Application — create at: GitLab Settings > Applications -->
        <oauth application-id="${GITLAB_APPLICATION_ID:}"
               application-secret="${GITLAB_APPLICATION_SECRET:}"
               callback-path="/api/v1/auth/gitlab/callback"
               scopes="api,read_user,read_repository"/>

        <!-- Personal Access Token (alternative to OAuth) -->
        <token value="${GITLAB_TOKEN:}"/>

        <!-- Webhook — GitLab sends X-Gitlab-Token with this value -->
        <webhook enabled="true"
                 secret="${GITLAB_WEBHOOK_SECRET:}"
                 path="/api/v1/webhooks/gitlab"/>
    </gitlab>

    <!-- ===================================================================== -->
    <!-- Bitbucket                                                             -->
    <!-- ===================================================================== -->
    <bitbucket enabled="${BITBUCKET_ENABLED:false}"
               base-url="${BITBUCKET_BASE_URL:https://bitbucket.org}"
               api-url="${BITBUCKET_API_URL:https://api.bitbucket.org/2.0}">

        <!-- OAuth Consumer — create at: Workspace Settings > OAuth consumers -->
        <oauth client-id="${BITBUCKET_CLIENT_ID:}"
               client-secret="${BITBUCKET_CLIENT_SECRET:}"
               callback-path="/api/v1/auth/bitbucket/callback"/>

        <!-- App Password auth (alternative to OAuth) -->
        <credentials username="${BITBUCKET_USERNAME:}"
                     app-password="${BITBUCKET_APP_PASSWORD:}"
                     token="${BITBUCKET_TOKEN:}"/>

        <!-- Webhook -->
        <webhook enabled="true"
                 secret="${BITBUCKET_WEBHOOK_SECRET:}"
                 path="/api/v1/webhooks/bitbucket"/>
    </bitbucket>

    <!-- ===================================================================== -->
    <!-- Azure DevOps                                                          -->
    <!-- ===================================================================== -->
    <!--
      Azure DevOps supports two authentication methods:
      1. PAT (Personal Access Token) - Simple, recommended for most use cases
      2. Azure AD (Entra ID) - For enterprise SSO with service principals
      
      For Service Hooks configuration:
      1. Go to Project Settings > Service Hooks
      2. Create a new Web Hook subscription
      3. Select "Pull request created" and "Pull request updated" events
      4. Set the URL to: https://your-domain/api/v1/webhooks/azure-devops
      5. Use HMAC-SHA256 authentication with the webhook secret below
    -->
    <azure-devops enabled="${AZURE_DEVOPS_ENABLED:false}"
                  organization="${AZURE_DEVOPS_ORGANIZATION:}"
                  base-url="${AZURE_DEVOPS_BASE_URL:https://dev.azure.com}">

        <!-- Personal Access Token — create at: User Settings > Personal access tokens -->
        <!-- Required scopes: Code (Read & Write), Pull Request Threads (Read & Write) -->
        <pat token="${AZURE_DEVOPS_PAT:}"/>

        <!-- Azure AD / Entra ID authentication (alternative to PAT) -->
        <!-- For service principal authentication in enterprise environments -->
        <azure-ad enabled="${AZURE_DEVOPS_USE_AZURE_AD:false}"
                  tenant-id="${AZURE_DEVOPS_TENANT_ID:}"
                  client-id="${AZURE_DEVOPS_CLIENT_ID:}"
                  client-secret="${AZURE_DEVOPS_CLIENT_SECRET:}"/>

        <!-- Webhook — Azure DevOps sends HMAC-SHA256 signed payloads -->
        <webhook enabled="true"
                 secret="${AZURE_DEVOPS_WEBHOOK_SECRET:}"
                 path="/api/v1/webhooks/azure-devops"/>

        <!-- Supported events -->
        <events>
            <event name="git.pullrequest.created" enabled="true"/>
            <event name="git.pullrequest.updated" enabled="true"/>
            <event name="git.pullrequest.merged" enabled="false"/>
        </events>
    </azure-devops>

</platforms>
