# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Markdown
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# XML
[*.xml]
indent_size = 2

# C/C++ Headers and Source
[*.{h,hpp,c,cpp,cc,cxx}]
indent_size = 4

# Java
[*.java]
indent_size = 4

# Kotlin (if used)
[*.{kt,kts}]
indent_size = 4

# Gradle
[*.gradle]
indent_size = 4

# Python
[*.py]
indent_size = 4

# JavaScript/TypeScript
[*.{js,ts,jsx,tsx}]
indent_size = 2

# Shell scripts
[*.sh]
indent_size = 2

# Batch files
[*.{bat,cmd}]
end_of_line = crlf
indent_size = 4

# PowerShell
[*.{ps1,psm1,psd1}]
indent_size = 4

# CMake
[CMakeLists.txt]
indent_size = 4

[*.cmake]
indent_size = 4

# Makefiles
[Makefile]
indent_style = tab

# Docker
[Dockerfile*]
indent_size = 4

# Groovy (Jenkins)
[*.groovy]
indent_size = 4

# TOML
[*.toml]
indent_size = 2
